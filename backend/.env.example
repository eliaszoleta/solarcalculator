PORT=3001
FRONTEND_URL=http://localhost:3000

# Generate a strong random string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string

# NREL PVWatts API key — free at https://developer.nrel.gov/signup/
# Without this key, the calculator uses state-average sun hours (still accurate)
NREL_API_KEY=DEMO_KEY

# Stripe — get keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
# Create a recurring price in Stripe Dashboard and paste the price ID here
STRIPE_PRICE_ID=price_...
# Webhook secret — from Stripe Dashboard > Webhooks (needed in production)
STRIPE_WEBHOOK_SECRET=whsec_...
