PORT=3001
FRONTEND_URL=http://localhost:3000

# Generate a strong random string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string

# NREL PVWatts API key — free at https://developer.nrel.gov/signup/
# Without this key, the calculator uses state-average sun hours (still accurate)
NREL_API_KEY=DEMO_KEY
